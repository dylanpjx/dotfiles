{
  "languageserver": {
    "ccls": {
      "command": "ccls",
      "args": ["--log-file=/tmp/ccls.log", "-v=1"],
      "filetypes": [
        "c",
        "cc",
        "cpp",
        "objc",
        "objcpp"
      ],
      "rootPatterns": [
        ".ccls",
        "compile_commands.json",
        ".vim/",
        ".git/",
        ".hg/"
      ],
      "initializationOptions": {
        "cache": {
          "directory": "/tmp/ccls"
        },
        "client": {
          "snippetSupport": true
        },
        "clang": {
          "extraArgs": ["-std=c++17"]
        }
      }
    }
  },
  "diagnostic.checkCurrentLine": true,
  "coc.preferences.formatOnSaveFiletypes": ["javascript", "css", "python","lua", "markdown"],
  "prettier.singleQuote": true,
  "prettier.trailingComma": "all",
  "prettier.disableLanguages": [],
  "signature.hideOnTextChange": true,
  "javascript.showUnused": false,
  "clangd.path": "/home/dylan/.config/coc/extensions/coc-clangd-data/install/12.0.0/clangd_12.0.0/bin/clangd"
}
